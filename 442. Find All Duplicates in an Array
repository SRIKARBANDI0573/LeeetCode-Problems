class Solution {
    public List<Integer> findDuplicates(int[] nums) {
        HashSet<Integer> hs = new HashSet<>();
        int n = nums.length;
        List<Integer> l = new ArrayList<>();
        for(int i = 0; i < n; i++){
            if(hs.contains(nums[i])){
                l.add(nums[i]);
            }
            else{
                hs.add(nums[i]);
            }
        }
        return l;
    }
}
