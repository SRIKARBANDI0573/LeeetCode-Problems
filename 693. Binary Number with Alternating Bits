class Solution {
    public boolean hasAlternatingBits(int n) {
        String num = " ";
        int res = 0;
        while(n>0){
            num = num+(n%2);
            n=n/2;
        }
        int len = num.length();
        for(int i = 0; i < len-1; i++){
            if(num.charAt(i) != num.charAt(i+1)){
                res=1;
            }
            else{
                res=0;
                break;
            }
        }
        if(res == 1){
            return true;
        }
        else{
            return false;
        }
    }
}
