class Solution {
    public int countBinarySubstrings(String s) {
        int n = s.length();

        int c = 1;
        int res=0;
        int prev=0;
        for(int i = 1; i < n ; i++){
            if(s.charAt(i) == s.charAt(i-1)){
                c++;
            }
            else{
                prev = c;
                c = 1;
            }
        if(c <= prev){
            res++;
        }
        }
        return res;
    }
}
