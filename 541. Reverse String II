class Solution {
    public void swap(char a[], int i, int j){
        while(i < j){
            char temp = a[i];
            a[i] = a[j];
            a[j] = temp;
            i++;
            j--;
        }
    }
    public String reverseStr(String s, int k) {
        int n = s.length();
        int i = 0;
        char a[] = s.toCharArray();
        while(i < n){
            int j = Math.min(i+k-1 , n - 1);
            swap(a,i,j);
            i = i+2*k;
        }
        return new String(a);
    }
}
