class Solution {
    public int countNegatives(int[][] grid) {
        int n = grid.length;
        int m =grid[0].length;

        ArrayList<Integer> a = new ArrayList<>();
        for(int i = 0; i < n; i++){
            for(int j = 0; j < m; j++){
                a.add(grid[i][j]);
            }
        }
        int c = 0;
        for(int i = 0; i < a.size(); i++){
            if(a.get(i) < 0){
                c++;
            }
        }
        return c;
    }
}
