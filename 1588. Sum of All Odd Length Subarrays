class Solution {
    public int sumOddLengthSubarrays(int[] arr) {
        int n = arr.length;
        int res = 0;
        for(int i = 0; i < n; i++){
            for(int j = i; j < n; j++){
                 int x = j - i + 1;
                 if(x % 2 != 0){
                    int sum = 0;
                    for(int k = i; k <= j; k++){
                        sum += arr[k];
                    }
                    res +=sum;
                 }
            }
        }
        return res;
    }
}
