class Solution {
    public int maxIceCream(int[] costs, int coins) {
        int n = costs.length;
        Arrays.sort(costs);
        int c = 0;
        int sum = 0;
        for(int i = 0; i < n; i++){
            if(sum + costs[i] <= coins){
                sum = sum + costs[i];
            c++;
            }
            else{
                break;
            }
        }
        return c;
    }
}
