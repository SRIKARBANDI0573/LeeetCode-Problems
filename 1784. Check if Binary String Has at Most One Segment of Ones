class Solution {
    public boolean checkOnesSegment(String s) {
        int c = 0;
        int n = s.length();
        for(int i = 0; i < n; i++){
            if(s.charAt(i) == '1' &&  (i == 0 || s.charAt(i-1) == '0')){
                c++;
            }
        }
        if(c > 1){
            return false;
        }
        else{
            return true;
        }
    }
}
