class Solution {
    public boolean judgeSquareSum(int c) {
        boolean f = false;
        int sum = 0;
        long p1 = 0;
        long p2 = (long)Math.sqrt(c);
        if(c == 1 || c == 0){
            return true;
        }
        while(p1 <= p2){
            if(p1 * p1 + p2 * p2 == c){
                return true;
            }
            else if(p1 * p1 + p2 * p2 > c){
                p2--;
            }
            else{
                p1++;
            }
        }
        return false;
