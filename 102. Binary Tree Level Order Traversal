/**
 * Definition for a binary tree node.
 * public class TreeNode {
 *     int val;
 *     TreeNode left;
 *     TreeNode right;
 *     TreeNode() {}
 *     TreeNode(int val) { this.val = val; }
 *     TreeNode(int val, TreeNode left, TreeNode right) {
 *         this.val = val;
 *         this.left = left;
 *         this.right = right;
 *     }
 * }
 */
class Solution {
    public List<List<Integer>> levelOrder(TreeNode root) {
        Queue<TreeNode> q = new LinkedList<>();
        List<List<Integer>> l = new ArrayList<>();
        List<Integer> temp = new ArrayList<>();
        if(root == null){
            return l;
        }
        q.add(root);
        q.add(null);
        while(!q.isEmpty()){
                TreeNode x = q.poll();
                if(x != null){
                temp.add(x.val);
                if(x.left != null){
                    q.add(x.left);
                }
                if(x.right != null){
                    q.add(x.right);
                }
            }
            else{
               if(!q.isEmpty()){
                q.add(null);
               }
               l.add(temp);
               temp = new ArrayList<>();
            }
        }
        return l;
    }
}
