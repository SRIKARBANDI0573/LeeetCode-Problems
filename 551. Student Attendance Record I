class Solution {
    public boolean checkRecord(String s) {
        int c = 0;
        int x = 0;
        int a = 0;
        for(char ch : s.toCharArray()){
            if(ch == 'A'){
                a++;
            }
        }
        if(a >= 2){
            return false;
        }
        for(char ch : s.toCharArray()){
            if(ch == 'L'){
                c++;
                if(c == 3){
                    return false;
                
                }
            }
            else{
                c = 0;
            }
        }
        return true;
    }
}
