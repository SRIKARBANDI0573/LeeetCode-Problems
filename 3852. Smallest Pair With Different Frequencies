class Solution {
    public int[] minDistinctFreqPair(int[] nums) {
        int a[] = new int[101];

        for(int i : nums){
            a[i]++;
        }
        int res [] = {-1 , -1};
        Arrays.sort(nums);
        for(int i = 0; i < nums.length; i++){
            if(i > 0 && nums[i] == nums[i-1]){
                continue;
            }
            for(int j = i+1; j < nums.length; j++){
                if(j > 0 && nums[j] == nums[j-1]){
                    continue;
                }
                if(a[nums[i]] != a[nums[j]]){
                    return new int []{nums[i] , nums[j]};
                }
            }
        }
        return new int[]{-1 , -1};
    }
}
