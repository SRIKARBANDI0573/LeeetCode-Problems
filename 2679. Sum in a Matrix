class Solution {
    public int matrixSum(int[][] nums) {
        int n = nums.length;
        int m = nums[0].length;
        int y = 0;
        for(int row[] : nums){
            Arrays.sort(row);
        }
        for(int i = 0; i < m; i++){
            int x = nums[0][i];
            for(int j = 1; j < n; j++){
                 if(x < nums[j][i]){
                    x = nums[j][i];
                 } 
            }
            y += x;
        }
        return y;
    }
}
