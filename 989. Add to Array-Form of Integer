class Solution {
    public List<Integer> addToArrayForm(int[] num, int k) {
        int n = num.length;
        
        List<Integer> l = new ArrayList<>();
        for(int i = n-1; i >= 0; i--){
            int x =num[i] + k;
            l.add(x%10);
            k = x/10;

        }
        while(k > 0){ 
            l.add(k % 10);
            k = k / 10;
        }
        Collections.reverse(l);
        return l;
    }
}
