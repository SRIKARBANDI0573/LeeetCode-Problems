class Solution {
    public int[] leftRightDifference(int[] nums) {
        int n = nums.length;
        int lsum[] = new int[n];
        int rsum[] = new int[n];
        int x = 0;
        for(int i = 1; i < n; i++){
            x += nums[i-1];
            lsum[i] = x;
        }
        int y = 0;
        for(int j = n-2; j >= 0; j--){
            y += nums[j+1]; 
            rsum[j] = y;
        }
        int ans[] = new int[n];

        for(int i = 0; i <n ; i++){
            ans[i] = Math.abs(lsum[i] - rsum[i]);
        }
        return ans;
    }
}
