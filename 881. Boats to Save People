class Solution {
    public int numRescueBoats(int[] people, int limit) {
        int n = people.length;
        int c = 0;
        Arrays.sort(people);
        int l = 0;
        int r = n-1;

        while(l <= r){
            if(l == r){
                c++;
                break;
            }
            else if(people[l] + people[r] <= limit){
                c++;
                l++;
                r--;
            }
            else{
                c++;
                r--;
            }
        }
        return c;
    }
}
